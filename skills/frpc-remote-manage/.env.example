# frpc Remote Management Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === SSH Connection ===
FRPC_SSH_HOST=1.2.3.4
FRPC_SSH_PORT=22
FRPC_SSH_USER=root

# SSH authentication (key takes priority over password)
FRPC_SSH_KEY=~/.ssh/id_rsa
# FRPC_SSH_PASS=your_password

# === frpc Configuration ===
# Remote path to frpc config file (.ini or .toml)
FRPC_CONFIG_PATH=/etc/frp/frpc.ini

# Command to restart frpc service
FRPC_RESTART_CMD=systemctl restart frpc
